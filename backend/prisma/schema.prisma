generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  TECHNICIAN
  READONLY
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  JAZZCASH
  EASYPAISA
  BANK
  CARD
  OTHER
}

enum RouterType {
  MIKROTIK
}

enum OltVendor {
  HUAWEI
  VSOL
  ZTE
  CDATA
  BDCOM
  FIBERHOME
  OTHER
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  username  String   @unique
  password  String
  role      UserRole @default(ADMIN)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Router {
  id       String     @id @default(cuid())
  name     String
  type     RouterType @default(MIKROTIK)
  host     String
  apiPort  Int        @default(8729)
  username String
  password String
  ssl      Boolean    @default(true)
  active   Boolean    @default(true)

  model    String?
  version  String?
  identity String?

  customers   Customer[]
  pppAccounts PppAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternetPackage {
  id              String  @id @default(cuid())
  name            String  @unique
  downloadMbps    Int
  uploadMbps      Int
  price           Float
  mikrotikProfile String
  active          Boolean @default(true)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String  @id @default(cuid())
  customerNo  String  @unique
  fullName    String
  fatherName  String?
  cnic        String?
  phone       String
  whatsapp    String?
  email       String?
  address     String?
  gpsLocation String?

  status CustomerStatus @default(ACTIVE)

  routerId  String
  packageId String

  router  Router          @relation(fields: [routerId], references: [id])
  package InternetPackage @relation(fields: [packageId], references: [id])

  pppAccount PppAccount?
  invoices   Invoice[]
  payments   Payment[]

  installationDate DateTime  @default(now())
  dueDate          DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PppAccount {
  id String @id @default(cuid())

  customerId String @unique
  routerId   String

  username String  @unique
  password String
  profile  String
  service  String  @default("pppoe")
  localIp  String?
  remoteIp String?
  callerId String?
  disabled Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
  router   Router   @relation(fields: [routerId], references: [id])

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Invoice {
  id         String @id @default(cuid())
  invoiceNo  String @unique
  customerId String

  amount     Float
  paidAmount Float @default(0)
  balance    Float @default(0)

  status    InvoiceStatus @default(PENDING)
  issueDate DateTime      @default(now())
  dueDate   DateTime

  customer Customer  @relation(fields: [customerId], references: [id])
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id         String  @id @default(cuid())
  customerId String
  invoiceId  String?

  amount    Float
  method    PaymentMethod @default(CASH)
  reference String?
  notes     String?

  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
}

model OltDevice {
  id       String    @id @default(cuid())
  name     String
  vendor   OltVendor
  host     String
  port     Int       @default(22)
  username String
  password String
  active   Boolean   @default(true)

  onus OnuDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnuDevice {
  id           String  @id @default(cuid())
  oltId        String
  serialNumber String  @unique
  ponPort      String
  onuId        String?
  vlan         Int?
  rxPower      Float?
  txPower      Float?
  distance     Float?
  online       Boolean @default(false)

  customerName  String?
  customerPhone String?

  olt OltDevice @relation(fields: [oltId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
