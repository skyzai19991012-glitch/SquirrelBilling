generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  OPERATOR
  TECHNICIAN
  READONLY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  JAZZCASH
  EASYPAISA
  BANK
  CARD
  OTHER
}

enum RouterType {
  MIKROTIK
}

enum OltVendor {
  HUAWEI
  VSOL
  ZTE
  CDATA
  BDCOM
  FIBERHOME
  OTHER
}

enum DeviceConnectionStatus {
  NOT_TESTED
  CONNECTED
  FAILED
}

model Tenant {
  id          String       @id @default(cuid())
  name        String       @unique
  companyName String?
  ownerName   String?
  email       String?
  phone       String?
  address     String?
  status      TenantStatus @default(ACTIVE)

  planName     String @default("STARTER")
  monthlyPrice Float  @default(0)

  maxCustomers Int @default(300)
  maxRouters   Int @default(1)
  maxOlts      Int @default(1)

  subscriptionStart DateTime  @default(now())
  subscriptionEnd   DateTime?

  users       User[]
  routers     Router[]
  packages    InternetPackage[]
  customers   Customer[]
  pppAccounts PppAccount[]
  invoices    Invoice[]
  payments    Payment[]
  olts        OltDevice[]
  onus        OnuDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String   @id @default(cuid())
  tenantId String?
  fullName String
  username String   @unique
  password String
  role     UserRole @default(ADMIN)
  active   Boolean  @default(true)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Router {
  id       String     @id @default(cuid())
  tenantId String?
  name     String
  type     RouterType @default(MIKROTIK)
  host     String
  apiPort  Int        @default(8729)
  username String
  password String
  ssl      Boolean    @default(true)
  active   Boolean    @default(true)

  connectionStatus DeviceConnectionStatus @default(NOT_TESTED)
  lastTestedAt     DateTime?
  lastError        String?

  model    String?
  version  String?
  identity String?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customers   Customer[]
  pppAccounts PppAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model InternetPackage {
  id       String  @id @default(cuid())
  tenantId String?

  name            String  @unique
  downloadMbps    Int
  uploadMbps      Int
  price           Float
  mikrotikProfile String
  active          Boolean @default(true)

  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Customer {
  id          String  @id @default(cuid())
  tenantId    String?
  customerNo  String  @unique
  fullName    String
  fatherName  String?
  cnic        String?
  phone       String
  whatsapp    String?
  email       String?
  address     String?
  gpsLocation String?

  status CustomerStatus @default(ACTIVE)

  routerId  String
  packageId String

  tenant  Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  router  Router          @relation(fields: [routerId], references: [id])
  package InternetPackage @relation(fields: [packageId], references: [id])

  pppAccount PppAccount?
  invoices   Invoice[]
  payments   Payment[]

  installationDate DateTime  @default(now())
  dueDate          DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([routerId])
  @@index([packageId])
}

model PppAccount {
  id       String  @id @default(cuid())
  tenantId String?

  customerId String @unique
  routerId   String

  username String  @unique
  password String
  profile  String
  service  String  @default("pppoe")
  localIp  String?
  remoteIp String?
  callerId String?
  disabled Boolean @default(false)

  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  router   Router   @relation(fields: [routerId], references: [id])

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([routerId])
}

model Invoice {
  id         String  @id @default(cuid())
  tenantId   String?
  invoiceNo  String  @unique
  customerId String

  amount     Float
  paidAmount Float @default(0)
  balance    Float @default(0)

  status    InvoiceStatus @default(PENDING)
  issueDate DateTime      @default(now())
  dueDate   DateTime

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id])
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model Payment {
  id         String  @id @default(cuid())
  tenantId   String?
  customerId String
  invoiceId  String?

  amount    Float
  method    PaymentMethod @default(CASH)
  reference String?
  notes     String?

  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([invoiceId])
}

model OltDevice {
  id       String    @id @default(cuid())
  tenantId String?
  name     String
  vendor   OltVendor
  host     String
  port     Int       @default(22)
  username String
  password String
  active   Boolean   @default(true)

  connectionStatus DeviceConnectionStatus @default(NOT_TESTED)
  lastTestedAt     DateTime?
  lastError        String?

  tenant Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  onus   OnuDevice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model OnuDevice {
  id           String  @id @default(cuid())
  tenantId     String?
  oltId        String
  serialNumber String  @unique
  ponPort      String
  onuId        String?
  vlan         Int?
  rxPower      Float?
  txPower      Float?
  distance     Float?
  online       Boolean @default(false)

  customerName  String?
  customerPhone String?

  tenant Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  olt    OltDevice @relation(fields: [oltId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([oltId])
}
